            "miDebuggerServerAddress": ":9999",
            "debugServerPath": "/home/gpf/code/dreamcast/lxdream-nitro/builddir/lxdream-nitro",
            "debugServerArgs": "--gdb-sh4=9999 -A null ${workspaceRoot}/vice/vice.cdi -n",
            "filterStdout": true,
            "filterStderr": true,
            // run on connect
            "stopAtConnect": false,
            // stop at main
            "stopAtEntry": true,
            "externalConsole": false,
            "avoidWindowsConsoleRedirection": false,
            "internalConsoleOptions": "openOnSessionStart",
            "launchCompleteCommand": "exec-run",
            "serverStarted": "SH4 GDB server running on port",
            "useExtendedRemote": true
        },
        {
            "name": "VICE x64 debug on lxdream-nitro",
            "type": "cppdbg",
            "request": "launch",
            "preLaunchTask": "VICE Build",
            "cwd": "${workspaceRoot}",
            "program": "${workspaceRoot}/vice/src/x64.elf",
            "MIMode": "gdb",
            "miDebuggerPath": "/opt/toolchains/dc/sh-elf/bin/sh-elf-gdb",
            "setupCommands": [{
                "text": "set architecture sh",
                "description": "Set GDB Arch to SuperH",
                "ignoreFailures" : false
            }],
            "miDebuggerServerAddress": ":9999",
            "debugServerPath": "/home/gpf/code/dreamcast/lxdream-nitro/builddir/lxdream-nitro",
            "debugServerArgs": "--gdb-sh4=9999 -A VICE ${workspaceRoot}/vice/vice.cdi -n",
            "filterStdout": true,
            "filterStderr": true,
            "stopAtConnect": true,
            "stopAtEntry": true,
            "externalConsole": false,
            "avoidWindowsConsoleRedirection": false,
            "internalConsoleOptions": "openOnSessionStart",
            "launchCompleteCommand": "exec-run",
            "serverStarted": "SH4 GDB server running on port",
            "useExtendedRemote": true,
            "enableJustMyCode": true,
            "loadAllModules": false
        },
        {
            "name": "debug on flycast",
            "type": "cppdbg",
            "request": "launch",
            "cwd": "${workspaceRoot}",
            "program": "${workspaceRoot}/build/cannonball.elf",
            "MIMode": "gdb",
            "miDebuggerPath": "/opt/toolchains/dc/sh-elf/bin/sh-elf-gdb",
            "setupCommands": [
                {
                    "text": "set architecture sh",
                    "description": "Set GDB Arch to SuperH",
                    "ignoreFailures": false
                }
            ],
            "miDebuggerServerAddress": ":9999",
            "debugServerPath": "/home/gpf/code/dreamcast/flycast/build/flycast",
            "debugServerArgs": "-config config:Debug.GDBEnabled=yes -config config:Debug.GDBPort=9999 -config config:Debug.GDBWaitForConnection=yes -config window:maximized=no /home/gpf/code/dreamcast/UE1/build/unreal.cdi",
            "filterStdout": true,
            "filterStderr": true,
            "stopAtConnect": true,
            "stopAtEntry": true,
